NODE_ENV=development
PORT=5000

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Contraseña de la base de datos (Settings → Database → Database password)
SUPABASE_DB_PASSWORD=your-database-password

# Región del proyecto (Dashboard → West US Oregon = us-west-2)
SUPABASE_DB_REGION=us-west-2

# Opcional: URI exacta del panel Connect → URI (prioridad máxima si falla auto-detect)
# DATABASE_URL=postgresql://postgres.ppkyeiirvequmwfnzxlv:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Inserta datos demo al arrancar (false para desactivar)
SEED_DEMO_DATA=true

# Usuario Supabase Auth para login en el frontend (se crea si no existe)
DEMO_USER_EMAIL=admin@smartstock.com
DEMO_USER_PASSWORD=SmartStock2024!